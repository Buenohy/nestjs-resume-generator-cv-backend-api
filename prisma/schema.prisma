// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Individual experience records
model Experience {
  id        String   @id @default(uuid())
  language  String
  role      String // Job title (e.g., Frontend Developer)
  company   String // Company (e.g., Google)
  url       String? // Company URL (optional)
  date      String // Period (e.g., "January 2022 - Present")
  details   String[] // List of project details and achievements
  stacks    String[] // Technologies used
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Snapshots of generated CVs
model ResumeHistory {
  id            String   @id @default(uuid())
  orderNumber   Int      @unique @default(autoincrement()) // Sequential order tracking number
  targetRole    String // Target role
  targetCompany String // Target company
  cvPayload     Json // JSON payload containing the complete snapshot
  createdAt     DateTime @default(now())
}
